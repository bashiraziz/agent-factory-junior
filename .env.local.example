# Copy this to .env.local and fill in your values

# Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/database?sslmode=require"

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# LLM Provider — "mock" uses no API keys, "gemini" uses Google AI
LLM_PROVIDER="gemini"

# Gemini model — change to any model you have access to
GEMINI_MODEL="gemini-2.0-flash"

# Google Gemini API key — get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Optional: other providers (not yet implemented)
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
